# --- Python ---
.venv/
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# --- Node / webapp ---
node_modules/
webapp/node_modules/
webapp/dist/
dist/
*.local
.vite/

# --- Local tooling & editor config (not for publishing) ---
.claude/
.qodo/
.vscode/
.idea/

# --- Data / models / outputs (kept as empty dirs via .gitkeep) ---
models/*.pt
models/*.pth
models/*.ckpt
data/*
!data/.gitkeep
outputs/*
!outputs/.gitkeep

# --- OS / misc ---
.DS_Store
Thumbs.db
*.log
